{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "bacon/bacon-qr-code": "^3.0",
        "coingate/coingate-php": "^4.1",
        "cviebrock/eloquent-sluggable": "^11.0",
        "diglactic/laravel-breadcrumbs": "^9.0",
        "ezyang/htmlpurifier": "^4.17",
        "hashids/hashids": "^5.0",
        "intervention/image": "^3.8",
        "iyzico/iyzipay-php": "^2.0",
        "laravel/framework": "^11.9",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.9",
        "laravel/ui": "*",
        "league/flysystem-aws-s3-v3": "^3.29",
        "livewire/livewire": "^3.5",
        "maatwebsite/excel": "^3.1",
        "mercadopago/dx-php": "^3.3",
        "midtrans/midtrans-php": "^2.6",
        "mollie/laravel-mollie": "^3.1",
        "pragmarx/google2fa-laravel": "^2.2",
        "propaganistas/laravel-disposable-email": "^2.4",
        "razorpay/razorpay": "^2.9",
        "rosell-dk/webp-convert": "^2.9",
        "socialiteproviders/microsoft": "^4.5",
        "socialiteproviders/vkontakte": "^5.0",
        "spatie/laravel-sitemap": "^7.2",
        "spatie/schema-org": "^3.23",
        "stripe/stripe-php": "^17.2",
        "uddoktapay/laravel-sdk": "^2.1",
        "vironeer/toastr": "^1.0",
        "xendit/xendit-php": "^6.3",
        "yoomoney/yookassa-sdk-php": "^3.8"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Vironeer\\": "vironeer/",
            "Vironeer\\Installer\\": "vironeer/installer/",
            "Vironeer\\Installer\\App\\": "vironeer/installer/app",
            "Vironeer\\PayPal\\": "vironeer/paypal-sdk",
            "Vironeer\\NOWPayments\\": "vironeer/nowpayments",
            "Vironeer\\Flutterwave\\": "vironeer/flutterwave"
        },
        "files": [
            "app/Helpers/General.php",
            "app/Helpers/Theme.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
